# Cloudflare
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ROOT_DOMAIN=yourdomain.lol
CLOUDFLARE_TUNNEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Discord
DISCORD_TOKEN=discord_bot_token
DISCORD_APP_ID=application_id
DISCORD_GUILD_ID=server_id
DISCORD_REQUIRED_ROLE_ID=role_id

# Github
GITHUB_TOKEN=github_pat_or_fine_grained_token
GITHUB_OWNER=yourname
GITHUB_REPO=exists.lol

# Misc
REGISTRY_DIR=domains
REDIRECT_CNAME=exists.lol
UPDATE_MODE=docker
APP_DIR=/app
LOG_DIR=/app/data
SYSTEMD_SERVICE=existsbot

# API
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8080
API_PUBLIC_URL=https://api.exists.lol
API_TOKEN=dev-secret
API_INTERNAL_URL=http://localhost:8080
