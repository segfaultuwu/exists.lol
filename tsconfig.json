{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "types": ["bun-types"],
    "skipLibCheck": true,
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["docs", "node_modules"],
}
